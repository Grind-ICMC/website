# Auth.js session secret. Generate a random value for each environment.
AUTH_SECRET=

# GitHub OAuth app used by the /login flow.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# GitHub token used by the server to read/write the admin repositories:
# Grind-ICMC/meetings, Grind-ICMC/docs, and Grind-ICMC/studies.
GITHUB_ADMIN_TOKEN=
